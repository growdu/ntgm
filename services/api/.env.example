# ============================================================
# NTGM API — Environment Variables
# Copy this file to .env in services/api/ and fill in values
# ============================================================

APP_ENV=development
APP_NAME=ntgm-api
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+psycopg://ntgm:ntgm@localhost:5432/ntgm

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Object Storage (MinIO / S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ntgm-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# JWT Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_DAYS=7

# Expo Push Notifications
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
EXPO_ACCESS_TOKEN=
PUSH_DRY_RUN=true

# Reminder Dispatch
REMINDER_DISPATCH_INTERVAL_SECONDS=60

# Sentry Monitoring (https://sentry.io — empty to disable)
SENTRY_DSN=
