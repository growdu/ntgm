# 基础
APP_ENV=development
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# 数据库 / 队列
DATABASE_URL=postgresql+psycopg://ntgm:ntgm@localhost:5432/ntgm
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 对象存储
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ntgm-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=***

# 鉴权
JWT_SECRET=***
JWT_EXPIRES_DAYS=7

# 邮箱（mock 模式下不会真发邮件，但保留 key 给未来）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@ntgm.app
SMTP_PASSWORD=***
EMAIL_FROM=no-reply@ntgm.app

# 支付（默认 mock，stripe=test 时走 Stripe test mode）
NTGM_CHECKOUT=mock
NEXT_PUBLIC_NTGM_CHECKOUT=mock
STRIPE_SECRET_KEY=sk_test_***
STRIPE_WEBHOOK_SECRET=whsec_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_***

# OpenAI / LLM
OPENAI_API_KEY=sk-***

# 推送通知（mobile → backend → Expo Push API）
# 设置后 mobile 端自动切到 http 模式
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
EXPO_ACCESS_TOKEN=
# true=只记录不发，false=真发到设备（生产环境改为 false）
NTGM_PUSH_DRY_RUN=true
